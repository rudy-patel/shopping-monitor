SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Optional: Supabase dashboard Account → Access Tokens (DDL migrations; not the service-role key)
SUPABASE_ACCESS_TOKEN=
AUTH_BYPASS_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Grounded search/discover uses its own model. Flash-Lite has a separate free-tier
# quota pool from Flash and returns grounded JSON in ~1-2s — recommended default.
GEMINI_SEARCH_MODEL=gemini-2.5-flash-lite
GEMINI_CATEGORIZE_TIMEOUT_S=1.5
GEMINI_DISCOVER_TIMEOUT_S=30.0
GEMINI_SEARCH_TIMEOUT_S=20.0
SEARCH_CACHE_TTL_HOURS=24
RESEND_API_KEY=
RESEND_FROM_EMAIL="Shopping Monitor <onboarding@resend.dev>"
WORKER_TOKEN=
# Required for local POST /internal/jobs/* smoke (must match X-Worker-Token header)
APP_BASE_URL=http://localhost:3000
SCRAPER_MODE=fixtures
LOG_LEVEL=INFO
# Comma-separated origins; production should include deployed frontend + localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
